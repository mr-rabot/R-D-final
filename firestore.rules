rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /siteSettings/{document} {
      allow read: if true;
      allow write: if true; // In a production app, restrict this to admin uids
    }
    match /inquiries/{inquiry} {
      allow create: if true;
      allow read, update, delete: if true; // Restrict in production
    }
    match /{document=**} {
      allow read, write: if true; // Restrict for production
    }
  }
}

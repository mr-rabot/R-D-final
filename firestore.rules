rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ACADEFLOW SOLUTIONS SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements an administrative CMS model with a public-facing frontend.
     * Security is anchored by a sentinel collection (/admin_roles) which identifies
     * administrators without requiring expensive get() calls in every rule.
     *
     * Data Structure:
     * - Public Content: Page content, services, blog posts, etc., are stored in top-level
     *   collections and are publicly readable if marked as 'published'.
     * - User Submissions: Inquiries and Quote Requests allow anonymous creation but 
     *   restrict all reading and management to administrators.
     * - Metadata: File metadata is stored both at the top level (for site assets) and 
     *   nested under submissions (for private attachments).
     *
     * Key Security Decisions:
     * - Authorization Independence: Admin status is verified via the existence of a 
     *   document in /admin_roles/{userId}.
     * - Structural Segregation: Private inquiry data and public site data are kept in 
     *   separate collections to maintain clean security boundaries.
     * - Immutability: Critical relational fields (like creator IDs) are protected
     *   against modification during updates.
     */

    // --- Helper Functions ---

    // Returns true if the user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns true if the user has an admin role sentinel document.
    // This avoids get() calls on the AdminUser profile and enables high performance.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // Checks if the user is the owner based on the provided userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if a document exists and belongs to the user (for updates/deletes).
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Admin profile management. Users can manage their own profile; SuperAdmins can manage all.
     * @path /adminUsers/{adminId}
     * @allow get, list, create, update: if isOwner(adminId) || isAdmin();
     * @deny delete: if !isAdmin();
     * @principle Ownership and Role-based access.
     */
    match /adminUsers/{adminId} {
      allow get, list: if isOwner(adminId) || isAdmin();
      allow create: if isOwner(adminId) || isAdmin();
      allow update: if isExistingOwner(adminId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Sentinel collection to define admin privileges.
     * @path /admin_roles/{adminId}
     * @allow read: if isSignedIn();
     * @deny write: if !isAdmin(); 
     * @principle Authorization Independence.
     */
    match /admin_roles/{adminId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Metadata for site-wide files. Admins can manage; public can read.
     * @path /files/{fileId}
     * @allow get, list: if true;
     * @allow create: if isAdmin() && request.resource.data.uploadedByAdminId == request.auth.uid;
     * @deny update, delete: if !isAdmin();
     * @principle Public Read with Owner-Only Writes.
     */
    match /files/{fileId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.uploadedByAdminId == request.auth.uid;
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description CMS content collections (PageContent, Service, PricingPlan, Testimonial, BlogPost, Tag, Resource, FAQ).
     * @path /{collection}/{id}
     * @allow get, list: if isAdmin() || resource.data.published == true;
     * @allow create, update, delete: if isAdmin();
     * @principle Structural Segregation using 'published' flag and Role-based writes.
     */
    match /pageContents/{id} {
      allow get, list: if isAdmin() || resource.data.published == true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /services/{id} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /pricingPlans/{id} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /testimonials/{id} {
      allow get, list: if isAdmin() || resource.data.published == true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /blogPosts/{id} {
      allow get, list: if isAdmin() || resource.data.published == true;
      allow create: if isAdmin() && request.resource.data.authorAdminId == request.auth.uid;
      allow update: if isAdmin() && resource != null && request.resource.data.authorAdminId == resource.data.authorAdminId;
      allow delete: if isAdmin() && resource != null;
    }
    match /tags/{id} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /resources/{id} {
      allow get, list: if isAdmin() || resource.data.published == true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }
    match /faqs/{id} {
      allow get, list: if isAdmin() || resource.data.published == true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description General contact inquiries. Anyone can submit; only admins can view/manage.
     * @path /inquiries/{inquiryId}
     * @allow create: if true;
     * @deny read, update, delete: if !isAdmin();
     * @principle Anonymous creation with Admin-only management.
     */
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;

      /**
       * @description Files attached to a specific inquiry.
       * @path /inquiries/{inquiryId}/attachedFiles/{fileId}
       * @allow create: if true;
       * @deny read, update, delete: if !isAdmin();
       * @principle Path-based segregation for private inquiry attachments.
       */
      match /attachedFiles/{fileId} {
        allow create: if true;
        allow get, list: if isAdmin();
        allow update, delete: if isAdmin() && resource != null;
      }
    }

    /**
     * @description Service quote requests. Anyone can submit; only admins can view/manage.
     * @path /quoteRequests/{quoteRequestId}
     * @allow create: if true;
     * @deny read, update, delete: if !isAdmin();
     * @principle Anonymous creation with Admin-only management.
     */
    match /quoteRequests/{quoteRequestId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;

      /**
       * @description Files attached to a specific quote request.
       * @path /quoteRequests/{quoteRequestId}/attachedFiles/{fileId}
       * @allow create: if true;
       * @deny read, update, delete: if !isAdmin();
       * @principle Path-based segregation for private quote attachments.
       */
      match /attachedFiles/{fileId} {
        allow create: if true;
        allow get, list: if isAdmin();
        allow update, delete: if isAdmin() && resource != null;
      }
    }

  }
}